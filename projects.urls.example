# Add one Supavisor session pooler URL per line. Inline comments work like .env comments.
# TLS is always used, so sslmode is not required; any sslmode in the URL is ignored.
postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres # production

# Blank lines are ignored. Quote a URL if it needs a literal # character.
postgresql://postgres.OTHER_PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres # staging
